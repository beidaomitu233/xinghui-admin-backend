<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xinghuiTec.mapper.SysMenuMapper">

    <!-- 菜单结果映射 -->
    <resultMap type="com.xinghuiTec.domain.entity.SysMenu" id="SysMenuMap">
        <result property="menuId" column="menu_id" />
        <result property="menuName" column="menu_name" />
        <result property="parentId" column="parent_id" />
        <result property="orderNum" column="order_num" />
        <result property="path" column="path" />
        <result property="component" column="component" />
        <result property="isFrame" column="is_frame" />
        <result property="menuType" column="menu_type" />
        <result property="visible" column="visible" />
        <result property="status" column="status" />
        <result property="perms" column="perms" />
        <result property="icon" column="icon" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="isDeleted" column="is_deleted" />
    </resultMap>

    <!-- ==================== 仅保留需要关联查询的SQL ==================== -->

    <!-- 根据角色ID查询权限标识列表（需要关联sys_role_menu表） -->
    <select id="selectPermsByUserId" resultType="java.lang.String">
        SELECT DISTINCT m.perms
        FROM sys_menu m
        LEFT JOIN sys_role_menu rm ON m.menu_id = rm.menu_id
        WHERE rm.role_id = #{roleId}
          AND m.perms IS NOT NULL
          AND m.perms != ''
          AND m.status = '0'
    </select>

    <!-- 根据多个角色ID批量查询权限标识 -->
    <select id="selectPermsByRoleIds" resultType="java.lang.String">
        SELECT DISTINCT m.perms
        FROM sys_menu m
        LEFT JOIN sys_role_menu rm ON m.menu_id = rm.menu_id
        WHERE rm.role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
          AND m.perms IS NOT NULL
          AND m.perms != ''
          AND m.status = '0'
    </select>

    <!-- 根据用户ID查询路由菜单 -->
    <select id="selectMenuByUserId" resultMap="SysMenuMap">
        SELECT DISTINCT m.*
        FROM sys_menu m
        LEFT JOIN sys_role_menu rm ON m.menu_id = rm.menu_id
        LEFT JOIN sys_user_role ur ON rm.role_id = ur.role_id
        WHERE ur.user_id = #{userId}
          AND m.menu_type IN ('M', 'C')
          AND m.status = '0'
        ORDER BY m.parent_id, m.order_num
    </select>

</mapper>
